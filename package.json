{
  "name": "spark-and-drive-autos",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "node scripts/prep-dev.mjs && NEXT_DISABLE_DEVTOOLS=1 next dev -p 5173",
    "dev:quick": "next dev --turbopack -p 5173",
    "dev:webpack": "node scripts/prep-dev.mjs && next dev -p 5173",
    "dev:clean": "rm -rf .next && next dev --turbopack -p 5173",
    "dev:fresh": "node scripts/kill-port.mjs 5173 && node scripts/prep-dev.mjs && next dev --turbopack -p 5173",
    "kill:5173": "node scripts/kill-port.mjs 5173",
    "doctor": "node scripts/doctor.mjs",
    "audit:routes": "node scripts/audit-routes.mjs",
    "audit:links": "node scripts/audit-links.mjs",
    "smoke:production": "node scripts/smoke-production.mjs",
    "env:bootstrap": "node scripts/ensure-local-env.mjs",
    "build": "node -e \"try { require('node:fs').rmSync('.next', { recursive: true, force: true }); } catch (_) {}\" && next build",
    "build:incremental": "next build",
    "build:clean": "npm run build",
    "typecheck": "npx tsc --noEmit",
    "test:paste-summary": "tsx --test tests/paste-summary/*.test.ts",
    "validate": "npm run lint && npm run typecheck && npm run test:parts-finder && npm run test:paste-summary",
    "validate:full": "npm run validate && npm run build",
    "env:validate:prod": "node scripts/validate-env.mjs",
    "test:parts-finder": "tsx --test tests/parts-finder/*.test.ts",
    "start": "node scripts/start.mjs",
    "worker:parts-finder": "tsx src/workers/parts-finder-worker.ts",
    "docker:up": "docker compose up -d --wait",
    "docker:down": "docker compose down",
    "setup:local": "npm run env:bootstrap && docker compose up -d --wait && npx prisma db push && npm run db:seed",
    "lint": "eslint",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "seed:admin": "tsx scripts/seed-super-admin.ts",
    "db:create-admin": "tsx scripts/create-admin.ts",
    "db:studio": "prisma studio",
    "backup:db": "bash scripts/backup-db.sh",
    "backup:full": "bash scripts/backup-full.sh",
    "restore:db": "bash scripts/restore-db.sh"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@base-ui/react": "^1.3.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^5.2.2",
    "@prisma/client": "^5.22.0",
    "@tanstack/react-query": "^5.96.2",
    "@tanstack/react-query-devtools": "^5.96.2",
    "@types/dompurify": "^3.2.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "cloudinary": "^2.9.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dompurify": "^3.3.3",
    "framer-motion": "^12.38.0",
    "jose": "^6.2.2",
    "lucide-react": "^1.7.0",
    "nanoid": "^5.1.7",
    "next": "15.5.14",
    "next-auth": "^5.0.0-beta.30",
    "next-themes": "^0.4.6",
    "pdf-lib": "^1.17.1",
    "prisma": "^5.22.0",
    "pusher": "^5.3.3",
    "pusher-js": "^8.5.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.72.1",
    "recharts": "^2.15.4",
    "shadcn": "^4.1.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.5.14",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
