  NORMAL
  HIGH
  URGENT
}

enum LeadSourceChannel {
  INQUIRY
  CAR_REQUEST
  PARTS_SOURCING_REQUEST
  CHAT
  CHECKOUT
  MANUAL
}

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  EXPIRED
  REJECTED
}

enum OrderStatus {
  DRAFT
  PENDING_PAYMENT
  PAID
  PROCESSING
  SOURCING
  SHIPPED
  AT_PORT
  DUTY_PROCESSING
  CLEARED
  READY_FOR_DELIVERY
  DELIVERED
  CANCELLED
