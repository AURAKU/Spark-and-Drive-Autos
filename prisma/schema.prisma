/// Normalized shipment for monitoring (parts Ghana / parts China / car sea).
model Shipment {
  id                String                 @id @default(cuid())
  orderId           String
  kind              ShipmentKind
  /// For China parts or car: air/sea mode from `DeliveryMode`; null for Ghana domestic bundle.
  deliveryMode      DeliveryMode?
