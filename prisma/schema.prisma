model Part {
  id                 String           @id @default(cuid())
  slug               String           @unique
  title              String
  shortDescription   String?          @db.Text
  description        String?          @db.Text
  /// Canonical part valuation in RMB. Display currencies are derived from this where applicable.
  basePriceRmb       Decimal          @default(0) @db.Decimal(14, 2)
  /// Admin-only supplier or distributor cost (CNY) — never expose on public surfaces
  supplierCostRmb    Decimal?         @db.Decimal(14, 2)
  /// Legacy cached GHS (synced from basePriceRmb + FX on save); storefront derives from RMB
  priceGhs           Decimal          @db.Decimal(14, 2)
  category           String
  categoryId         String?
  origin             PartOrigin       @default(GHANA)
  sku                String?
  metaJson           Json?
  stockQty           Int              @default(0)
  stockStatus        PartStockStatus  @default(IN_STOCK)
  /// When false, stockStatus is auto-derived from stockQty (except ON_REQUEST stays manual-only)
  stockStatusLocked  Boolean          @default(false)
  listingState       PartListingState @default(DRAFT)
  tags               Json             @default("[]")
  coverImageUrl      String?
  coverImagePublicId String?
  featured           Boolean          @default(false)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  images          PartImage[]
  categoryRef     PartCategory?        @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  deliveryOptions PartDeliveryOption[]
  cartItems       PartCartItem[]
  favorites       PartFavorite[]
  orderItems      PartOrderItem[]
  reviews         Review[]

  @@index([category])
  @@index([categoryId])
  @@index([listingState])
  @@index([featured])
  @@index([createdAt])
  @@index([origin])
  @@index([sku])
}

