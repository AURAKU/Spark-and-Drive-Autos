  CUSTOMER
  SERVICE_ASSISTANT
  SUPER_ADMIN
  SALES_ADMIN
  SOURCING_MANAGER
  LOGISTICS_MANAGER
  FINANCE_ADMIN
}

enum EngineType {
  GASOLINE_PETROL
  GASOLINE_DIESEL
  ELECTRIC
  HYBRID
  PLUGIN_HYBRID
}

enum SourceType {
  IN_GHANA
  IN_CHINA
  IN_TRANSIT
}

enum AvailabilityStatus {
  AVAILABLE
  RESERVED
  SOLD
  COMING_SOON
  IN_TRANSIT_STOCK
  ON_REQUEST
}

enum InquiryType {
  GENERAL
  MORE_PHOTOS
  VIDEO_CALL
  SHIPPING_ESTIMATE
  DUTY_ESTIMATE
  RESERVE
  SIMILAR_CAR
  PRICE
  OTHER
}

enum InquiryStatus {
  NEW
  IN_PROGRESS
  RESPONDED
  CLOSED
}

enum CarRequestSourcePref {
  CHINA
  GHANA
  EITHER
}

enum CarRequestStatus {
  NEW
  REVIEWING
  SOURCING
  QUOTED
  CONVERTED
  CLOSED
}

enum PartsRequestStatus {
  NEW
  REVIEWING
  QUOTED
  FULFILLED
  CLOSED
