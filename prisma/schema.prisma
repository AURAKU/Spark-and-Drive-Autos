  MEDIUM
  HIGH
  CRITICAL
}

enum DisputeEvidenceType {
  PAYMENT_VERIFICATION
  RECEIPT
  ORDER_RECORD
  POLICY_ACCEPTANCE
  CONTRACT_ACCEPTANCE
  IDENTITY_VERIFICATION
  CHAT_TRANSCRIPT
  DELIVERY_RECORD
  SOURCING_APPROVAL
  PARTS_FINDER_RESULT
  ADMIN_NOTE
  CUSTOMER_UPLOAD
  PROVIDER_RESPONSE
  OTHER
}

enum PaymentProvider {
  PAYSTACK
  MANUAL
}

enum ReceiptTemplateScope {
  CAR
  PARTS
}

enum ReceiptType {
  CAR_PAYMENT
  PARTS_PAYMENT
  PARTS_FINDER_ACTIVATION
  SOURCING_DEPOSIT
  WALLET_TOPUP
  MANUAL_PAYMENT
  VERIFIED_PART_REQUEST
}

enum VerifiedPartRequestStatus {
  DRAFT
  AWAITING_PAYMENT
  PAID
  IN_REVIEW
  VERIFIED
  NEEDS_MORE_INFO
  FAILED
  CANCELLED
  REFUNDED
}

enum ReceiptStatus {
  ISSUED
  VOIDED
  REGENERATED
  FAILED
}

/// How the customer intends to settle (product-facing). Paystack checkouts use PAYSTACK; offline routes use other values.
enum PaymentSettlementMethod {
  PAYSTACK
  MOBILE_MONEY
  BANK_GHS_COMPANY
  ALIPAY_RMB
  CASH_OFFICE_GHS
  CASH_OFFICE_USD
}

enum ChatThreadStatus {
  OPEN
  ARCHIVED
}

enum MessageSenderType {
  USER
  ADMIN
  SYSTEM
}

enum MessageType {
  TEXT
  IMAGE
  FILE
  VIDEO
  AUDIO
}

enum CarListingState {
  DRAFT
  PUBLISHED
  HIDDEN
  SOLD
}

enum AttachmentKind {
  IMAGE
  VIDEO
  AUDIO
  FILE
}

enum PaymentProofStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PartsFinderMembershipStatus {
  ACTIVE
  EXPIRED
  SUSPENDED
}

enum PartsFinderSearchStatus {
  PENDING_REVIEW
  APPROVED
  REJECTED
  LOW_CONFIDENCE
  VERIFIED
  LIKELY
  FLAGGED_SOURCING
}

enum PartsFinderConfidenceLabel {
  VERIFIED_MATCH
  LIKELY_MATCH
  NEEDS_VERIFICATION
}

enum PartsFinderOutcomeStatus {
  VERIFIED
  LIKELY
  REJECTED
}

enum PartsFinderReferenceType {
  OEM
  ALTERNATE
}

enum PartsFinderVerificationStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum PartsFinderApprovalMode {
  AUTO
  MANUAL
}

enum PartListingState {
  DRAFT
  PUBLISHED
  HIDDEN
}

enum PartStockStatus {
  IN_STOCK
  LOW_STOCK
  OUT_OF_STOCK
  ON_REQUEST
}

enum PartOrigin {
  GHANA
  CHINA
}

enum DeliveryMode {
  AIR_EXPRESS
  AIR_STANDARD
  SEA
}

/// Admin input currency for China delivery template fees (stored fees are normalized to GHS + RMB for checkout).
enum DeliveryFeeCurrency {
  GHS
  USD
}

/// Shipment aggregate for an order (Ghana parts, China parts, or car sea).
enum ShipmentKind {
  PARTS_GHANA
  PARTS_CHINA
  CAR_SEA
}

/// Customer- and admin-facing logistics milestones (separate from `OrderStatus`).
enum ShipmentLogisticsStage {
  PENDING_SHIPPING_SETUP
  PROCESSING
  READY_FOR_DISPATCH
  IN_TRANSIT
  ARRIVED
  OUT_FOR_DELIVERY
  DELIVERED
  DELAYED
  CANCELLED
}

/// Import duty operations for vehicle orders (estimate vs official assessment is separate).
enum DutyWorkflowStage {
  NOT_STARTED
  DUTY_ESTIMATE_GENERATED
  AWAITING_ARRIVAL
  ARRIVED_AT_PORT
  AWAITING_OFFICIAL_ASSESSMENT
  DUTY_CONFIRMED
  AWAITING_DUTY_PAYMENT
  DUTY_PAYMENT_IN_PROGRESS
  DUTY_PAID
  CLEARANCE_IN_PROGRESS
  CLEARED
  DELIVERED_READY_FOR_PICKUP
}

enum VehicleImportEstimateStatus {
  DRAFT
  SENT
  ACCEPTED
  EXPIRED
  SUPERSEDED
}

enum DuplicateEntityType {
  CAR
  PART
}

enum DuplicateDecision {
  PENDING
  KEEP_BOTH
  MERGE_LATER
  CANCEL_CREATE
}

enum SecuritySeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum SecurityChannel {
  AUTH
  PAYMENT
  WEBHOOK
  RATE_LIMIT
  API
  ADMIN
  FRAUD
  MISCONFIG
}

enum ImportExportEntity {
  CARS
  PARTS
}

enum JobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum WalletTransactionStatus {
  PENDING
  SUCCESS
  FAILED
}

enum WalletTransactionDirection {
  CREDIT
  DEBIT
}

enum WalletTransactionPurpose {
  TOPUP
  PARTS_PURCHASE
  ADJUSTMENT
}

enum NotificationType {
  INQUIRY
  CHAT
  PAYMENT
  SHIPPING
  ORDER
  SYSTEM
}

enum TimelineStage {
  INQUIRY_RECEIVED
  SOURCING_STARTED
  SUPPLIER_CONFIRMED
  INSPECTION_COMPLETED
  PAYMENT_CONFIRMED
  SHIPPED
  AT_PORT
  DUTY_PROCESSING
  CUSTOMS_CLEARED
  READY_FOR_DELIVERY
  DELIVERED
}

model User {
  id                     String    @id @default(cuid())
  email                  String    @unique
  emailVerified          DateTime?
  passwordHash           String?
  name                   String?
  phone                  String?
  country                String?
  image                  String?
  ghanaCardIdNumber      String?
  ghanaCardImageUrl      String?
  ghanaCardImagePublicId String?
  walletBalance          Decimal   @default(0) @db.Decimal(14, 2)
  role                   UserRole  @default(CUSTOMER)
  /// When true, user cannot send chat messages (admin moderation).
  messagingBlocked       Boolean   @default(false)
  /// When true, user cannot sign in or use authenticated areas (policy / threat).
  accountBlocked         Boolean   @default(false)
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  favorites                    Favorite[]
  inquiries                    Inquiry[]
  carRequests                  CarRequest[]
  partSourcingRequests         PartSourcingRequest[]
  orders                       Order[]
  payments                     Payment[]
  chats                        ChatThread[]                     @relation("CustomerChats")
  leads                        Lead[]                           @relation("LeadCustomer")
  reviews                      Review[]
  notifications                Notification[]
  messages                     Message[]                        @relation("UserMessages")
  auditLogs                    AuditLog[]                       @relation("ActorAudit")
  assignedLeads                Lead[]                           @relation("LeadOwner")
  quotesForCustomer            Quote[]                          @relation("QuoteCustomer")
  quotesCreated                Quote[]                          @relation("QuoteCreator")
  paymentProofsUploaded        PaymentProof[]                   @relation("PaymentProofUploader")
  paymentProofsReviewed        PaymentProof[]                   @relation("PaymentProofReviewedBy")
  paymentsReviewed             Payment[]                        @relation("PaymentReviewedBy")
  paymentStatusEvents          PaymentStatusHistory[]           @relation("PaymentStatusActor")
  paymentVerificationsReviewed PaymentVerification[]            @relation("PaymentVerificationReviewer")
  policyVersionsCreated        PolicyVersion[]                  @relation("PolicyVersionCreator")
  contractVersionsCreated      Contract[]                       @relation("ContractCreator")
  policyAcceptances            UserPolicyAcceptance[]
  paymentDisputesFlagged       PaymentDispute[]                 @relation("PaymentDisputeFlagger")
  paymentDisputesResolved      PaymentDispute[]                 @relation("PaymentDisputeResolver")
  legalAuditLogsActor          LegalAuditLog[]                  @relation("LegalAuditActor")
  legalAuditLogsTarget         LegalAuditLog[]                  @relation("LegalAuditTarget")
  currencySettingsUpdated      GlobalCurrencySettings[]         @relation("CurrencyUpdatedBy")
  passwordResetTokens          PasswordResetToken[]
  duplicateChecksReviewed      DuplicateCheckEvent[]
  securityObservations         SecurityObservation[]
  importJobsCreated            ImportJob[]
  exportJobsCreated            ExportJob[]
  addresses                    UserAddress[]
  walletTransactions           WalletTransaction[]
  partCarts                    PartCart[]
  partFavorites                PartFavorite[]
  agreementLogs                AgreementLog[]
  contractAcceptances          ContractAcceptance[]
  riskAcknowledgements         RiskAcknowledgement[]
  riskTags                     UserRiskTag[]                    @relation("RiskTagUser")
  riskTagsCreated              UserRiskTag[]                    @relation("RiskTagCreator")
  riskEvents                   RiskEvent[]
  systemAnnouncementsCreated   SystemAnnouncement[]             @relation("SystemAnnouncementCreator")
  shipmentStatusEventsAuthored ShipmentStatusEvent[]            @relation("ShipmentStatusEventActor")
  dutyRecordsUpdated           DutyRecord[]                     @relation("DutyRecordUpdatedBy")
  partsFinderMemberships       PartsFinderMembership[]
  partsFinderSearchSessions    PartsFinderSearchSession[]       @relation("PartsFinderSessionUser")
  partsFinderReviewedSessions  PartsFinderSearchSession[]       @relation("PartsFinderSessionReviewer")
  partsFinderReviewOverrides   PartsFinderSearchSessionReview[] @relation("PartsFinderOverrideReviewer")
  partsFinderConversions       PartsFinderConversion[]
  partsFinderResults           PartsFinderResult[]
  partsFinderVerifiedOutcomes  PartsFinderVerifiedOutcome[]     @relation("PartsFinderOutcomeReviewer")
  partsFinderSupportVerifications PartsFinderSupportVerification[] @relation("PartsFinderSupportVerificationReviewer")
  vehicleImportEstimatesPrepared  VehicleImportEstimate[]       @relation("VehicleImportEstimatePreparedBy")
  vehicleImportEstimatesForCustomer VehicleImportEstimate[]     @relation("VehicleImportEstimateCustomer")
  vehicleImportEstimatesSent       VehicleImportEstimate[]       @relation("VehicleImportEstimateSentBy")
  vehicleImportEstimateEvents      VehicleImportEstimateEvent[] @relation("VehicleImportEstimateEventActor")
  receiptTemplatesCreated          ReceiptTemplate[]             @relation("ReceiptTemplateCreator")
  generatedReceipts                GeneratedReceipt[]            @relation("GeneratedReceiptUser")
  generatedReceiptsByActor         GeneratedReceipt[]            @relation("GeneratedReceiptActor")
  receiptAuditLogs                 ReceiptAuditLog[]             @relation("ReceiptAuditActor")
  paymentProviderConfigsCreated    PaymentProviderConfig[]       @relation("PaymentProviderConfigCreator")
  paymentProviderConfigsUpdated    PaymentProviderConfig[]       @relation("PaymentProviderConfigUpdater")
  verifications                    UserVerification[]
  verificationsReviewed            UserVerification[]            @relation("UserVerificationReviewer")
  verificationAuditLogsActor       VerificationAuditLog[]        @relation("VerificationAuditActor")
  verificationAuditLogsUser        VerificationAuditLog[]        @relation("VerificationAuditUser")
  disputesOpened                   DisputeCase[]                 @relation("DisputeCaseUser")
  disputesAssigned                 DisputeCase[]                 @relation("DisputeCaseAssignee")
  disputesCreated                  DisputeCase[]                 @relation("DisputeCaseCreator")
  disputeEvidenceAdded             DisputeEvidence[]             @relation("DisputeEvidenceActor")
  disputeTimelineEvents            DisputeTimelineEvent[]        @relation("DisputeTimelineActor")
  disputeActionLogs                DisputeActionLog[]            @relation("DisputeActionActor")
  userVehicles                     UserVehicle[]
  verifiedPartRequests             VerifiedPartRequest[] @relation("VerifiedPartRequestUser")
  verifiedPartRequestsAssigned     VerifiedPartRequest[] @relation("VerifiedPartRequestAssignee")
}

/// Audit log row when an admin broadcasts an in-app announcement to all user accounts.
model SystemAnnouncement {
  id             String   @id @default(cuid())
  title          String
  body           String?  @db.Text
  recipientCount Int
  createdAt      DateTime @default(now())
  createdById    String?
  createdBy      User?    @relation("SystemAnnouncementCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([createdAt])
}

model UserAddress {
  id             String   @id @default(cuid())
  userId         String
  fullName       String
  phone          String
  region         String
  city           String
  district       String?
  locality       String?
  digitalAddress String?
  streetAddress  String
  landmark       String?
  notes          String?
  isDefault      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user       User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  partOrders Order[] @relation("PartOrderDeliveryAddress")

  @@index([userId, isDefault])
}

model UserVehicle {
  id        String   @id @default(cuid())
  userId    String
  vin       String?
  make      String
  model     String
  year      Int
  engine    String?
  trim      String?
  nickname  String?
  isDefault Boolean  @default(false)
  nextServiceReminder DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  verifiedPartRequests VerifiedPartRequest[]

  @@index([userId, createdAt])
  @@index([userId, make, model, year])
  @@index([vin])
  @@index([userId, vin])
}

model WalletTransaction {
  id              String                     @id @default(cuid())
  userId          String
  reference       String                     @unique
  provider        PaymentProvider            @default(PAYSTACK)
  method          PaymentSettlementMethod    @default(MOBILE_MONEY)
  amount          Decimal                    @db.Decimal(14, 2)
  currency        String                     @default("GHS")
  status          WalletTransactionStatus    @default(PENDING)
  direction       WalletTransactionDirection @default(CREDIT)
  purpose         WalletTransactionPurpose   @default(TOPUP)
  orderId         String?
  providerPayload Json?
  paidAt          DateTime?
  createdAt       DateTime                   @default(now())
  updatedAt       DateTime                   @updatedAt

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  order Order? @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([status])
  @@index([orderId])
}

model Car {
  id                 String             @id @default(cuid())
  slug               String             @unique
  title              String
  brand              String
  model              String
  year               Int
  trim               String?
  bodyType           String?
  engineType         EngineType
  transmission       String?
  drivetrain         String?
  mileage            Int?
  colorExterior      String?
  colorInterior      String?
  vin                String?
  condition          String?
  engineDetails      String?            @db.Text
  sourceType         SourceType
  availabilityStatus AvailabilityStatus @default(AVAILABLE)
  inspectionStatus   String?
  estimatedDelivery  String?
  /// Estimated sea freight to Ghana (GHS), shown on listing/checkout; copied onto car shipment when paid.
  seaShippingFeeGhs  Decimal?           @db.Decimal(14, 2)
  /// Canonical inventory valuation in Chinese Yuan (single source of truth for conversions)
  basePriceRmb       Decimal            @default(0) @db.Decimal(14, 2)
  /// Admin-only supplier or dealership cost (CNY) — never expose on public surfaces
  supplierCostRmb    Decimal?           @db.Decimal(14, 2)
  /// Admin-only: supplier or dealer name (never shown on public vehicle pages)
  supplierDealerName         String?    @db.VarChar(200)
  /// Admin-only: contact phone for traceability
  supplierDealerPhone        String?    @db.VarChar(40)
  /// Admin-only: order / invoice / ref to trace the unit
  supplierDealerReference    String?    @db.Text
  /// Admin-only: free-text notes to trace sourcing
  supplierDealerNotes        String?    @db.Text
  /// Legacy display fields — optional overrides; prefer deriving from basePriceRmb + GlobalCurrencySettings
  price              Decimal            @db.Decimal(14, 2)
  currency           String             @default("GHS")
  location           String?
  featured           Boolean            @default(false)
  listingState       CarListingState    @default(DRAFT)
  tags               Json?
  shortDescription   String?
  longDescription    String?            @db.Text
  specifications     Json?
  accidentHistory    String?
  coverImageUrl      String?
  coverImagePublicId String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  images    CarImage[]
  videos    CarVideo[]
  specs     CarSpecification[]
  inquiries Inquiry[]
  favorites Favorite[]
  orders    Order[]
  chats     ChatThread[]
  quotes    Quote[]
  vehicleImportEstimates VehicleImportEstimate[]

  @@index([brand, model])
  @@index([listingState, featured])
  @@index([sourceType])
  @@index([availabilityStatus])
}

model CarImage {
  id        String   @id @default(cuid())
  carId     String
  url       String
  publicId  String?
  sortOrder Int      @default(0)
  altText   String?
  isCover   Boolean  @default(false)
  createdAt DateTime @default(now())

  car Car @relation(fields: [carId], references: [id], onDelete: Cascade)

  @@index([carId, sortOrder])
}

model CarVideo {
  id           String   @id @default(cuid())
  carId        String
  url          String
  publicId     String?
  sortOrder    Int      @default(0)
  durationSec  Int?
  thumbnailUrl String?
  isFeatured   Boolean  @default(false)
  createdAt    DateTime @default(now())

  car Car @relation(fields: [carId], references: [id], onDelete: Cascade)

  @@index([carId, sortOrder])
}

model CarSpecification {
  id        String @id @default(cuid())
  carId     String
  label     String
  value     String
  sortOrder Int    @default(0)

  car Car @relation(fields: [carId], references: [id], onDelete: Cascade)

  @@index([carId])
}

model Inquiry {
  id         String        @id @default(cuid())
  carId      String?
  userId     String?
  guestName  String?
  guestEmail String?
  guestPhone String?
  type       InquiryType   @default(GENERAL)
  message    String        @db.Text
  status     InquiryStatus @default(NEW)
  leadId     String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  car     Car?         @relation(fields: [carId], references: [id], onDelete: SetNull)
  user    User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  lead    Lead?        @relation(fields: [leadId], references: [id], onDelete: SetNull)
  threads ChatThread[]
  vehicleImportEstimates VehicleImportEstimate[]

  @@index([carId])
  @@index([status])
  @@index([createdAt])
}

model CarRequest {
  id                 String               @id @default(cuid())
  userId             String?
  guestName          String
  guestEmail         String
  guestPhone         String
  country            String?
  brand              String
  model              String
  yearFrom           Int?
  yearTo             Int?
  trim               String?
  engineType         EngineType?
  transmission       String?
  colorPreference    String?
  budgetMin          Decimal?             @db.Decimal(14, 2)
  budgetMax          Decimal?             @db.Decimal(14, 2)
  currency           String               @default("GHS")
  destinationCountry String?
  destinationCity    String?
  sourcePreference   CarRequestSourcePref @default(EITHER)
  notes              String?              @db.Text
  status             CarRequestStatus     @default(NEW)
  leadId             String?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  user   User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  lead   Lead?        @relation(fields: [leadId], references: [id], onDelete: SetNull)
  quotes Quote[]
  chats  ChatThread[]
  disputeCases DisputeCase[]

  @@index([status])
  @@index([createdAt])
}

model Lead {
  id            String            @id @default(cuid())
  customerId    String?
  stage         LeadStage         @default(NEW)
  priority      LeadPriority      @default(NORMAL)
  sourceChannel LeadSourceChannel @default(MANUAL)
  ownerId       String?
  nextFollowUp  DateTime?
  lastContacted DateTime?
  internalNotes String?           @db.Text
  title         String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  customer             User?                 @relation("LeadCustomer", fields: [customerId], references: [id], onDelete: SetNull)
  owner                User?                 @relation("LeadOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  inquiries            Inquiry[]
  carRequests          CarRequest[]
  partSourcingRequests PartSourcingRequest[]
  chats                ChatThread[]
  quotes               Quote[]
  orders               Order[]

  @@index([stage])
  @@index([customerId])
}

/// Signed-in customer request for parts or accessories not found in the catalog (with optional reference photos).
model PartSourcingRequest {
  id           String             @id @default(cuid())
  userId       String
  summaryTitle String?            @db.VarChar(200)
  description  String             @db.Text
  vehicleMake  String?            @db.VarChar(80)
  vehicleModel String?            @db.VarChar(80)
  vehicleYear  Int?
  partNumber   String?            @db.VarChar(120)
  quantity     Int                @default(1)
  urgency      String?            @db.VarChar(40)
  deliveryCity String?            @db.VarChar(120)
  imageUrls    String[]           @default([])
  status       PartsRequestStatus @default(NEW)
  leadId       String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  lead Lead? @relation(fields: [leadId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([status])
  @@index([createdAt])
}

model Quote {
  id              String      @id @default(cuid())
  leadId          String?
  carId           String?
  carRequestId    String?
  customerId      String?
  createdById     String?
  vehicleCost     Decimal?    @db.Decimal(14, 2)
  sourcingFee     Decimal?    @db.Decimal(14, 2)
