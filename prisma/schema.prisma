/// Singleton row (id = "default") — global FX for RMB / USD / GHS
model GlobalCurrencySettings {
  id          String   @id @default("default")
  /// 1 USD equals how many RMB (CNY)
  usdToRmb    Decimal  @db.Decimal(18, 6)
  /// Divisor D for RMB→GHS: GHS = round(RMB / D); GHS→RMB: RMB = GHS × D
  rmbToGhs    Decimal  @db.Decimal(18, 6)
  /// 1 USD equals how many GHS (direct: GHS = USD × rate; USD = GHS / rate)
  usdToGhs    Decimal  @db.Decimal(18, 6)
  updatedAt   DateTime @updatedAt
  updatedById String?
  updatedBy   User?    @relation("CurrencyUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
}

