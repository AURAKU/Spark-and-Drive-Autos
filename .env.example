# -----------------------------------------------------------------------------
# Copy to ".env" and replace every placeholder. Do not commit your real ".env".
# -----------------------------------------------------------------------------

# One-time admin bootstrap (lost DB / new server). Do NOT leave in production .env after use.
# Run:  npm run db:create-admin
# BOOTSTRAP_ADMIN_EMAIL="owner@yourdomain.com"
# BOOTSTRAP_ADMIN_PASSWORD="use-a-long-random-password"
# BOOTSTRAP_ADMIN_NAME="Site Owner"

# PostgreSQL — use 127.0.0.1 (not "localhost") avoids common IPv6/IPv4 mismatches.
# Replace YOUR_DB_USER, YOUR_DB_PASSWORD, YOUR_DATABASE with your real values.
# If you use the repo's Docker Compose database, open docker-compose.yml and use the
# POSTGRES_* values there for user, password, and database name; host port is 5433.
DATABASE_URL="postgresql://YOUR_DB_USER:YOUR_DB_PASSWORD@127.0.0.1:5433/YOUR_DATABASE?schema=public"

# Auth.js / NextAuth — must be at least 32 characters. Generate for real use:
#   openssl rand -base64 32
# The value below is a non-secret placeholder so local tools can validate length;
# replace it before any shared or production environment.
AUTH_SECRET="PLACEHOLDER_REPLACE_WITH_openssl_rand_base64_32_chars_min"
NEXTAUTH_SECRET="PLACEHOLDER_REPLACE_WITH_openssl_rand_base64_32_chars_min"

# Must match the exact origin you open in the browser (scheme + host + port).
# Dev server listens on all interfaces; use http://localhost:5173 (shown as "Local" by next dev).
# If cookies/auth misbehave, align this with whatever is in the address bar (localhost vs 127.0.0.1).
AUTH_URL="http://localhost:5173"
NEXTAUTH_URL="http://localhost:5173"

# Google OAuth (optional — enables "Continue with Google" on login/register)
# Create OAuth client: Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs
# Authorized redirect URI: http://localhost:5173/api/auth/callback/google (plus production URL)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Apple Sign-In is OFF by default. Set to 1 only when you are ready to configure Apple + test callbacks.
ENABLE_APPLE_OAUTH="0"

# Apple OAuth (optional — only when ENABLE_APPLE_OAUTH=1)
# Callback URL (must use HTTPS in production; match AUTH_URL):
#   http://localhost:5173/api/auth/callback/apple
# Option A — pre-generated client-secret JWT (e.g. from `npx auth add apple`):
AUTH_APPLE_ID=""
AUTH_APPLE_SECRET=""
# Option B — generate JWT at runtime (recommended for rotation). Omit AUTH_APPLE_SECRET when using this:
# APPLE_TEAM_ID="YOUR_TEAM_ID"
# APPLE_KEY_ID="YOUR_KEY_ID"
# APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...lines from .p8...\n-----END PRIVATE KEY-----"

# Password reset email delivery (production)
# Uses Resend API in /api/auth/forgot-password when NODE_ENV=production.
RESEND_API_KEY=""
RESET_PASSWORD_FROM_EMAIL="Spark & Drive Gear <no-reply@example.com>"
RESET_PASSWORD_SHOW_DEV_LINK="0"

# Production: `npm run start` uses PORT if set (e.g. cloud), else 5173. Set AUTH_URL to your public URL.
# Optional: extra hosts for Server Actions (e.g. LAN test) — comma-separated host:port
# SERVER_ACTION_ALLOWED_ORIGINS="192.168.1.10:5173"

# Paystack (https://dashboard.paystack.com/#/settings/developer)
PAYSTACK_SECRET_KEY="sk_test_your_key_here"
PAYSTACK_PUBLIC_KEY="pk_test_your_key_here"
PAYSTACK_WEBHOOK_SECRET=""
# Optional explicit key for encrypting provider secrets in DB (recommended in production).
PROVIDER_SECRET_ENCRYPTION_KEY=""

# Cloudinary (signed uploads + CDN)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
# Optional: if you use a Cloudinary CNAME for delivery, set the hostname (no scheme) so payment-proof URLs validate
# CLOUDINARY_SECURE_HOST="images.example.com"

# Pusher Channels — optional near-real-time chat (private-chat-{threadId} + /api/chat/pusher-auth)
PUSHER_APP_ID=""
PUSHER_KEY=""
PUSHER_SECRET=""
PUSHER_CLUSTER="eu"

# Upstash Redis (optional distributed rate limits)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
# Optional self-hosted Redis URL fallback
REDIS_URL=""

# Parts Finder queue worker (required for production queue processing)
PARTS_FINDER_WORKER_IDLE_MS="1000"
PARTS_FINDER_WORKER_ERROR_BACKOFF_MS="3000"

# Optional AI provider config (non-blocking; summaries can be disabled gracefully)
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
AI_PROVIDER="none"

# One-time super admin seeding (idempotent)
# Run: npm run seed:admin
SEED_SUPER_ADMIN_EMAIL=""
SEED_SUPER_ADMIN_PASSWORD=""
SEED_SUPER_ADMIN_NAME=""

# Identity verification (risk-based trigger)
IDENTITY_VERIFICATION_HIGH_VALUE_GHS="20000"
